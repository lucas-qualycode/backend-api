# Local development only (emulator / uvicorn).
# Copy to .env.local — do NOT put MERCADOPAGO_ACCESS_TOKEN in .env when using Firebase secrets.
#
# Firebase deploy reads .env and sets plain environment variables on Cloud Run.
# The same name cannot be both a plain env var and a secret (deploy fails or token stays empty).

MERCADOPAGO_ACCESS_TOKEN=APP_USR-your-token-here
